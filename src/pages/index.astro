---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBlogPosts } from "../lib/blog";
import { isCraftConfigured } from "../lib/craft";

const configured = isCraftConfigured();
const posts = configured ? await getBlogPosts() : [];
const siteTitle = import.meta.env.SITE_TITLE ?? "Craft Journal";

function formatDate(value: string | undefined) {
  if (!value) {
    return "No date";
  }

  return new Intl.DateTimeFormat("ja-JP", {
    year: "numeric",
    month: "short",
    day: "numeric",
  }).format(new Date(value));
}
---

<BaseLayout title={siteTitle}>
  <section class="hero">
    <p class="eyebrow">Craft powered blog</p>
    <h1>{siteTitle}</h1>
    <p>Craft のドキュメントをデータソースにして、Astro が静的なブログとして出力します。</p>
  </section>

  {
    configured ? (
      posts.length ? (
        <section class="post-list" aria-label="Posts">
          {posts.map((post) => (
            <a class="post-row" href={`/posts/${post.slug}/`}>
              <time datetime={post.publishedAt}>{formatDate(post.publishedAt)}</time>
              <span>
                <h2>{post.title}</h2>
                {post.excerpt && <p>{post.excerpt}</p>}
                {post.tags.length > 0 && (
                  <ul class="tags" aria-label="Tags">
                    {post.tags.map((tag) => (
                      <li>{tag}</li>
                    ))}
                  </ul>
                )}
              </span>
            </a>
          ))}
        </section>
      ) : (
        <section class="setup">
          <h2>Craft の記事が見つかりませんでした</h2>
          <p><code>CRAFT_COLLECTION_ID</code> または <code>CRAFT_COLLECTION_NAME</code> の対象を確認してください。</p>
        </section>
      )
    ) : (
      <section class="setup">
        <h2>Craft API を接続してください</h2>
        <p>
          Craft の Imagine タブで API connection を作り、発行された API URL を
          <code>.env</code> に設定すると記事が表示されます。
        </p>
        <pre><code>CRAFT_API_BASE_URL="https://connect.craft.do/links/YOUR_ID/api/v1"
CRAFT_COLLECTION_NAME="Posts"
SITE_TITLE="Craft Journal"</code></pre>
      </section>
    )
  }
</BaseLayout>
