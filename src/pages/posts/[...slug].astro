---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Badge } from "@/components/ui/badge";
import { getBlogPages, getBlogPost } from "../../lib/blog";

export async function getStaticPaths() {
  const pages = await getBlogPages();

  return pages.map((post) => ({
    params: { slug: post.path },
  }));
}

const post = await getBlogPost(Astro.params.slug);

if (!post) {
  const basePath = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return Astro.redirect(basePath);
}

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBasePath = (path: string) => `${basePath}${path.replace(/^\//, "")}`;

function formatDate(value: string | undefined) {
  if (!value) {
    return "No date";
  }

  return new Intl.DateTimeFormat("ja-JP", {
    year: "numeric",
    month: "short",
    day: "numeric",
  }).format(new Date(value));
}
---

<BaseLayout title={post.title} description={post.excerpt}>
  <article>
    <header class="article-header">
      {post.breadcrumbs.length > 1 && (
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <ol>
            {post.breadcrumbs.map((crumb, index) => (
              <li>
                {index === post.breadcrumbs.length - 1 ? (
                  <span aria-current="page">{crumb.title}</span>
                ) : (
                  <a href={withBasePath(`posts/${crumb.path}/`)}>{crumb.title}</a>
                )}
              </li>
            ))}
          </ol>
        </nav>
      )}
      <Badge variant="outline" className="article-label">Article</Badge>
      <h1>{post.title}</h1>
      <p class="article-meta">
        <time datetime={post.publishedAt}>{formatDate(post.publishedAt)}</time>
        {post.updatedAt && <> / Updated {formatDate(post.updatedAt)}</>}
      </p>
      {post.tags.length > 0 && (
        <span class="tags" aria-label="Tags">
          {post.tags.map((tag) => (
            <Badge variant="secondary" className="tag-badge">{tag}</Badge>
          ))}
        </span>
      )}
    </header>
    <div class="post-body" set:html={post.html} />
  </article>
</BaseLayout>
