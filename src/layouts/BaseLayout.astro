---
type Props = {
  title: string;
  description?: string;
};

const siteTitle = import.meta.env.SITE_TITLE ?? "Craft Journal";
const { title, description = "A blog powered by Craft and Astro." } = Astro.props;
const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBasePath = (path: string) => `${basePath}${path.replace(/^\//, "")}`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={withBasePath("favicon.svg")} />
    <link rel="icon" href={withBasePath("favicon.ico")} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title === siteTitle ? title : `${title} | ${siteTitle}`}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={basePath}>{siteTitle}</a>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --paper: #fbfaf7;
    --ink: #181715;
    --muted: #706b63;
    --line: #dfd8cc;
    --accent: #216869;
    --accent-soft: #d7ebe8;
    --code: #f1ede5;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--paper);
    color: var(--ink);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    line-height: 1.6;
  }

  a {
    color: inherit;
  }

  .site-header {
    border-bottom: 1px solid var(--line);
  }

  .brand {
    display: block;
    width: min(1040px, calc(100% - 40px));
    margin: 0 auto;
    padding: 22px 0;
    color: var(--accent);
    font-weight: 750;
    text-decoration: none;
  }

  main {
    width: min(1040px, calc(100% - 40px));
    margin: 0 auto;
  }

  .eyebrow {
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 760;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .hero {
    padding: 72px 0 48px;
    border-bottom: 1px solid var(--line);
  }

  .hero h1 {
    max-width: 760px;
    margin: 10px 0 16px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.96;
    letter-spacing: 0;
  }

  .hero p {
    max-width: 640px;
    margin: 0;
    color: var(--muted);
    font-size: 1.1rem;
  }

  .post-list {
    display: grid;
    padding: 34px 0 80px;
    gap: 0;
  }

  .post-row {
    display: grid;
    grid-template-columns: minmax(110px, 180px) 1fr;
    gap: 28px;
    padding: 28px 0;
    border-bottom: 1px solid var(--line);
    text-decoration: none;
  }

  .post-row time {
    color: var(--muted);
    font-size: 0.94rem;
  }

  .post-row h2 {
    margin: 0 0 8px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.7rem, 3vw, 2.6rem);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .post-row p {
    max-width: 660px;
    margin: 0;
    color: var(--muted);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 14px 0 0;
    padding: 0;
    list-style: none;
  }

  .tags li {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 3px 10px;
    color: var(--accent);
    font-size: 0.82rem;
  }

  .setup {
    max-width: 720px;
    margin: 52px 0 80px;
    padding: 28px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fffdf9;
  }

  .setup h2 {
    margin: 0 0 10px;
    font-size: 1.25rem;
  }

  .setup code,
  .post-body code {
    border-radius: 5px;
    background: var(--code);
    padding: 0.12em 0.32em;
  }

  .setup pre,
  .post-body pre {
    overflow-x: auto;
    border-radius: 8px;
    background: var(--code);
    padding: 16px;
  }

  .post-header {
    max-width: 820px;
    padding: 70px 0 40px;
  }

  .post-header h1 {
    margin: 10px 0 14px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.8rem, 7vw, 5.7rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .post-meta {
    color: var(--muted);
  }

  .post-body {
    max-width: 760px;
    padding: 16px 0 88px;
    font-size: 1.08rem;
  }

  .post-body h1,
  .post-body h2,
  .post-body h3 {
    margin: 2em 0 0.45em;
    line-height: 1.16;
    letter-spacing: 0;
  }

  .post-body img {
    max-width: 100%;
    border-radius: 8px;
  }

  .post-body blockquote {
    margin-inline: 0;
    border-left: 3px solid var(--accent);
    padding-left: 18px;
    color: var(--muted);
  }

  @media (max-width: 680px) {
    main,
    .brand {
      width: min(100% - 28px, 1040px);
    }

    .hero {
      padding-top: 46px;
    }

    .post-row {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
